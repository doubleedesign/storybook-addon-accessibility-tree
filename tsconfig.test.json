{
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": ".",
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"jsx": "react",
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"lib": [
			"esnext",
			"dom",
			"dom.iterable"
		],
		"types": [
			"vitest/globals",
			"@testing-library/jest-dom/vitest",
			"@testing-library/dom"
		]
	},
	"include": [
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"vitest.setup.ts"
	]
}